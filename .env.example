# --- Local dev: everything below is OPTIONAL ---
# No PLAYGROUND_PASSWORD in dev  -> the auth gate is disabled (open site).
#   (In production an unset password fails CLOSED, never open.)
# No DATABASE_URL                -> a local PGlite Postgres file (./.pgdata) is used.
# No BLOB_STORE_ID               -> Asset Library uploads go to ./public/uploads/
#                                    instead of Vercel Blob (ADR-0005). Not meant to
#                                    be set by hand locally — Vercel provisions it
#                                    automatically once a Blob store is connected,
#                                    along with the OIDC token the SDK reads itself.

# Shared site password (server-side only — never prefix with NEXT_PUBLIC_).
# Also used as the HMAC secret for the session cookie.
PLAYGROUND_PASSWORD=

# Set to a Neon connection string in prod; leave empty to use the local file DB.
DATABASE_URL=

BLOB_STORE_ID=

# FAL API key. The Models page catalog fetch (ADR-0006) loads without it —
# setting it there only raises FAL's rate limits — but real generation
# (ADR-0009's queue.fal.run submit/status/result calls) needs it to
# authenticate against FAL at all. Server-side only; sent as
# `Authorization: Key <FAL_KEY>`, never exposed to the browser.
# FAL_KEY=
